<%- include('partials/header'); -%>

<h1><%= t('score.edit.state') %></h1>

<style>
  main {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #reader {
    width: 600px;
  }

  #result {
    text-align: center;
    font-size: 1.5rem;
  }
</style>

<div class="w3-panel w3-green divSuccess" style="display: none">
  <p class="pSuccess"><%= t('score.edit.state.success') %></p>
</div>
<div class="w3-panel w3-red divError" style="display: none">
  <p class="pError"><%= t('score.edit.state.error') %></p>
</div>

<form id="formScan">
  <button class="w3-button w3-black btnScan"><%= t('score.edit.state.scan') %></button>
</form>
<p></p>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

<main id="scanMain">
  <div id="reader"></div>
  <div id="result"></div>
</main>

<div class="w3-panel w3-border divScore" style="display: none">
  <form id="formEditState">
    <h3><%= t('scores') %></h3>
    <label>ID</label>
    <input type="text" name="scoreId" value="" class="w3-input scoreId" readonly>
    <label>Ext. ID</label>
    <input type="text" name="scoreExtId" value="" class="w3-input scoreExtId" readonly>
    <label><%= t('score.edit.state.label') %></label>
    <input type="text" name="state" value="" class="w3-input state">
    <p></p>
    <button class="w3-button w3-black btnSave"><%= t('score.edit.state.save') %></button>
    <p></p>
  </form>
</div>

<div class="divHome" style="display: none">
  <p></p>
  <a href="/admin/edit-score-state" class="w3-button w3-black"><%= t('score.edit.state.scan') %></a>
  <p></p>
  <a href="/" class="w3-button w3-black"><%= t('home') %></a>
</div>

<%- include('partials/footer'); -%>

<script>
  const formScan = document.querySelector('#formScan');
  const formEditState = document.querySelector('#formEditState');
  const btnScan = document.querySelector('.btnScan');
  const divScore = document.querySelector('.divScore');
  const divSuccess = document.querySelector('.divSuccess');
  const divError = document.querySelector('.divError');
  const divHome = document.querySelector('.divHome');

  var scanner;

  formScan.addEventListener('submit', async (e) => {
    e.preventDefault();
    divError.style = "display: none";
    formScan.style = "display: none";

    scanner = new Html5QrcodeScanner('reader', {
      qrbox: {
        width: 250,
        height: 250,
      },
      fps: 20,
    });
    scanner.render(scanSuccess, scanError);
  });

  formEditState.addEventListener('submit', async (e) => {
    e.preventDefault();
    divError.style = "display: none";

    const scoreId = document.querySelector('.scoreId').value;
    const state = document.querySelector('.state').value;
    await postUpdate(scoreId, state);
  });

  async function lookupScore(scoreId) {
    try {
      const res = await fetch('/admin/edit-score-state', {
        method: 'POST',
        body: JSON.stringify({ scoreId }),
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (data.errors) {
        showError(data.errors);
        return false;
      }
      if (data.score) {
        document.querySelector('.scoreId').value = data.score.id;
        document.querySelector('.scoreExtId').value = data.score.extId || '';
        document.querySelector('.state').value = data.score.state || '';
        divScore.style = "display: block";
        return true;
      }
    } catch (err) {
      showError(err.message);
    }
    return false;
  }

  async function postUpdate(scoreId, state) {
    try {
      const res = await fetch('/admin/edit-score-state/update', {
        method: 'POST',
        body: JSON.stringify({ scoreId, state }),
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (data.errors) {
        showError(data.errors);
        return;
      }
      if (data.score) {
        divScore.style = "display: none";
        divSuccess.style = "display: block";
        divError.style = "display: none";
        divHome.style = "display: block";
      }
    } catch (err) {
      showError(err.message);
    }
  }

  async function scanSuccess(result) {
    scanner.clear();
    document.getElementById('reader').remove();
    await lookupScore(result);
  }

  function scanError(err) {
    console.error(err);
  }

  function showError(message) {
    divError.style = "display: block";
    document.querySelector('.pError').textContent = message;
  }
</script>
